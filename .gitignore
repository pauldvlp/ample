# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local sqlite database (data is user-owned; keep migrations, not the db)
/data
*.db
*.db-wal
*.db-shm

# claude code local session state / MCP tool output (not project source)
.claude/settings.local.json
.playwright-mcp/

# npm publish staging output (regenerated by `pnpm stage:npm`)
/dist-npm

# playwright
/test-results
/playwright-report
/blob-report
