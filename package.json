{
  "name": "ample",
  "version": "0.2.0",
  "private": true,
  "description": "A complete, single-user personal finance app with the feel of a beautifully printed wealth statement — accounts, budgets, goals, debts, net worth and an optional bring-your-own-key AI assistant. Self-hosted, local-first SQLite.",
  "keywords": [
    "personal-finance",
    "budget",
    "self-hosted",
    "sqlite",
    "nextjs",
    "money"
  ],
  "homepage": "https://github.com/pauldvlp/ample#readme",
  "bugs": "https://github.com/pauldvlp/ample/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauldvlp/ample.git"
  },
  "author": "Paul Barahona <johanpaulbarahona@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "prepare": "husky || true",
    "predev": "pnpm db:migrate",
    "dev": "next dev -p ${PORT:-4211}",
    "prebuild": "pnpm db:migrate",
    "build": "next build",
    "start": "next start -p ${PORT:-4211}",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:agent": "sh __test/run.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "mkdir -p data && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "rm -f data/ample.db data/ample.db-wal data/ample.db-shm && pnpm db:migrate && pnpm db:seed",
    "docker": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "stage:npm": "node scripts/stage-npm-package.mjs",
    "pack:npm": "pnpm stage:npm && npm pack ./dist-npm"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@base-ui/react": "^1.6.0",
    "@google/genai": "^2.11.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "driver.js": "^1.7.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.47.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
